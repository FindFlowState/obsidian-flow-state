{
  "name": "flow-state-obsidian-plugin",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build-local": "node scripts/build.mjs --mode=local",
    "build-prod": "node scripts/build.mjs --mode=prod",
    "build": "node scripts/build.mjs --mode=local && node scripts/build.mjs --mode=prod",
    "typecheck": "tsc -p tsconfig.json --noEmit",
