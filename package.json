    "esbuild": "^0.21.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.5.8",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@sentry/browser": "^10.37.0",
    "@supabase/supabase-js": "^2.108.2",
    "mustache": "^4.2.0",
    "sanitize-filename": "^1.6.3"
